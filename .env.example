# --- App ---
APP_PORT=8180
SPRING_PROFILES_ACTIVE=local
CORS_ALLOWED_ORIGINS=http://localhost:4200
JWT_SECRET=change_me_long_random_secret
APP_EMAIL_FROM=no-reply@starter.com
FRONTEND_BASE_URL=http://localhost:4200

# --- Mail ---
MAIL_HOST=maildev
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
